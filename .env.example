# Database
DATABASE_URL='postgresql://user:password@host:port/database?schema=public'

# Next Auth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# AWS Storage (optional)
AWS_PROFILE="hosted_storage"
AWS_REGION="us-west-2"
AWS_BUCKET_NAME="your-bucket-name"
AWS_FOLDER_PREFIX="your-folder/"
ABACUSAI_API_KEY="your-abacus-api-key"

# Upstash Redis (optional — rate limiting da API pública /api/v1 e do chat widget)
# Sem estas variáveis, a API pública funciona normalmente, só sem rate limiting.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OpenAI (obrigatório para o chat de IA embedável — /dashboard/chat-widget)
# Sem esta variável, o widget responde com uma mensagem de indisponibilidade em vez de quebrar.
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"

# Stripe Payment (required — 6 Price IDs para os 3 planos x 2 intervalos de cobrança)
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_BASICO_MONTHLY_PRICE_ID="price_..."
STRIPE_BASICO_ANNUAL_PRICE_ID="price_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_BUSINESS_MONTHLY_PRICE_ID="price_..."
STRIPE_BUSINESS_ANNUAL_PRICE_ID="price_..."

# Stripe Payment em USD (mercado internacional — 6 Price IDs equivalentes em dólar)
STRIPE_BASICO_MONTHLY_PRICE_ID_USD="price_..."
STRIPE_BASICO_ANNUAL_PRICE_ID_USD="price_..."
STRIPE_PRO_MONTHLY_PRICE_ID_USD="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID_USD="price_..."
STRIPE_BUSINESS_MONTHLY_PRICE_ID_USD="price_..."
STRIPE_BUSINESS_ANNUAL_PRICE_ID_USD="price_..."

# Public App URL
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Evolution API (WhatsApp Integration - Legacy)
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your_master_api_key_here
EVOLUTION_WEBHOOK_SECRET=your_webhook_validation_secret

# n8n Integration (WhatsApp Notification Scheduling - v3.1)
# These endpoints are used for instance management and real-time polling
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/whatsapp-calenvo
N8N_CREATE_INSTANCE_URL=https://your-n8n-instance.com/webhook/criar-instancia
N8N_UPDATE_QR_CODE_URL=https://your-n8n-instance.com/webhook/criar-instancia
N8N_STATUS_URL=https://your-n8n-instance.com/webhook/status-da-instancia
N8N_DELETE_URL=https://your-n8n-instance.com/webhook/excluir-instancia
